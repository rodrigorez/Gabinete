# Gabinete Virtual — Template de Variáveis de Ambiente
# Copie este arquivo para .env e preencha com valores reais:
#   cp .env.example .env

# PIN de acesso administrativo (6 dígitos numéricos)
VITE_ADMIN_PIN=TROCAR_ANTES_DO_DEPLOY

# GitHub API — Token pessoal (Fine-grained, scope: Contents read/write)
VITE_GITHUB_TOKEN=
VITE_GITHUB_REPO=usuario/gabinete-config

# Supabase — Projeto para Storage de assets
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJ...
